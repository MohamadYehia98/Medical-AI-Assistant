APP_NAME= "Healthcare AI Assistant"
APP_VERSION= "0.1"
OPEN_API_KEY= ""

FILE_ALLOWED_TYPES= ["text/plain", "application/pdf"]
FILE_MAX_SIZE= 10
FILE_DEFAULT_CHUNK_SIZE= 512000 # 512 Kb

MONGODB_URL= "mongodb://admin:admin@localhost:27007"
MONGODB_DATABASE= "Rag"

# ======================= LLM Config ============================

GENERATION_BACKEND= "GEMINI"
EMBEDDING_BACKEND= "COHERE"


OPENAI_API_KEY= ""
OPENAI_API_URL=""


GEMINI_API_KEY=""
GENERATION_MODEL_ID="gemini-3.1-flash-lite"


COHERE_API_KEY=""
EMBEDDING_MODEL_ID= "embed-multilingual-light-v3.0"
EMBEDDING_MODEL_SIZE= 384

default_input_max_char= 1024
default_output_max_char= 200
temperature= 0.1

# ============================== Vector DB Config ===========================================


VECTORDB_BACKEND = "QDRANT"
VECTOR_DB_PATH = "qdrant_db"

VECTOR_DB_URL = ""
VECTOR_DB_API_KEY =""
VECTOR_DB_DISTANCE_METHOD = "cosine"

